{
  "name": "@pawd/bridge",
  "version": "1.0.0",
  "description": "Bridge server between Claude Agent SDK and Pawd mobile app",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:bg": "nohup npm run dev >> pawd-bridge.log 2>&1 & echo Started in background. Logs: pawd-bridge.log",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx src/seed.ts",
    "test:endpoints": "tsx scripts/test-endpoints.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.1.2",
    "pino": "^9.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
